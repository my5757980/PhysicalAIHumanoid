# ── LLM Provider ─────────────────────────────────────────────────────────────
# Default: OpenAI gpt-4o-mini
# To switch to Grok: set OPENAI_BASE_URL=https://api.x.ai/v1 and use an xAI key
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
# Grok model name when using xAI: grok-3-mini (uncomment and set OPENAI_BASE_URL)
OPENAI_MODEL=gpt-4o-mini

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Qdrant Cloud Free Tier ────────────────────────────────────────────────────
# Create free cluster at: https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=physical-ai-book

# ── Neon Serverless Postgres (optional — future auth/personalization) ──────────
# Create free DB at: https://neon.tech
NEON_DB_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ── Backend Server ────────────────────────────────────────────────────────────
BACKEND_PORT=8000
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:3000,https://PHYSICAL-AI-HUMANOID-ROBOTICS.vercel.app
ADMIN_SECRET=change-me-in-production
# Absolute path to repo root (used by ingest endpoint)
REPO_ROOT=.

# ── RAG Tuning ────────────────────────────────────────────────────────────────
TOP_K=6
MAX_HISTORY_TURNS=6
MAX_CHUNK_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
