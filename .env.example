# Environment variables for Vercel deployment

# The Vercel Edge API will automatically use the correct base URL in production
# No need to set VITE_BACKEND_URL for Vercel deployment

# Qdrant configuration (set these in Vercel dashboard)
# QDRANT_URL=your_qdrant_cluster_url
# QDRANT_API_KEY=your_qdrant_api_key

# Cohere configuration (set these in Vercel dashboard)
# COHERE_API_KEY=your_cohere_api_key