{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/ask_stream",
      "dest": "/api/ask_stream.js"
    },
    {
      "src": "/api/(.*)",
      "status": 404,
      "dest": "/404.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "api/ask_stream.js": {
      "runtime": "edge"
    }
  }
}